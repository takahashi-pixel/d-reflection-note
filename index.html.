<script>
var P=null,E={},W={},SC={cond:0,fat:0,score:0},INJ=false,WO=0;
var SCOLS=['','#C62828','#E65100','#D4A017','#3D7A2B','#1B5E20'];
var SLBLS=['','目標未達成','やや不満足','普通','良かった','最高の1日！'];
var DAYS=['日','月','火','水','木','金','土'];

function sv(k,v){try{localStorage.setItem(k,JSON.stringify(v));}catch(e){}}
function ld(k,d){try{var v=localStorage.getItem(k);return v?JSON.parse(v):d;}catch(e){return d;}}

function init(){
  P=ld('drn_p',null);E=ld('drn_e',{});W=ld('drn_w',{});
  if(P){show('sh');refreshHome();buildSel();}
  else{show('si');}/* 初回はイントロ画面 */
}

function show(id){document.querySelectorAll('.sc').forEach(function(s){s.classList.remove('on');});var el=document.getElementById(id);if(el){el.classList.add('on');if(el.querySelector('.sa'))el.querySelector('.sa').scrollTop=0;}}

function goToProfile(){show('sw');}

function nav(t){
  if(t==='home'){show('sh');refreshHome();}
  else if(t==='daily'){show('sd');setupDaily();}
  else if(t==='weekly'){show('swk');setupWeekly();}
  else if(t==='history'){show('shs');renderHist();}
  else if(t==='profile'){show('spe');loadProfileEdit();}
  else if(t==='about'){show('sab');}
}

/* ---- PROFILE SETUP (first time) ---- */
function setupProfile(){
  var n=document.getElementById('inp-name').value.trim();
  if(!n){alert('氏名を入力してください');return;}
  P={
    name:n,
    sid:document.getElementById('inp-sid').value.trim(),
    sport:document.getElementById('inp-sport').value.trim(),
    goal4year:document.getElementById('inp-goal').value.trim(),
    goalImportant:document.getElementById('inp-important').value.trim(),
    motto:document.getElementById('inp-motto').value.trim()
  };
  sv('drn_p',P);show('sh');refreshHome();buildSel();
}

/* ---- PROFILE EDIT ---- */
function loadProfileEdit(){
  if(!P)return;
  document.getElementById('ep-name').value=P.name||'';
  document.getElementById('ep-sid').value=P.sid||'';
  document.getElementById('ep-sport').value=P.sport||'';
  document.getElementById('ep-goal').value=P.goal4year||'';
  document.getElementById('ep-important').value=P.goalImportant||'';
  document.getElementById('ep-motto').value=P.motto||'';
}
function saveProfile(){
  var n=document.getElementById('ep-name').value.trim();
  if(!n){alert('氏名を入力してください');return;}
  P.name=n;P.sid=document.getElementById('ep-sid').value.trim();P.sport=document.getElementById('ep-sport').value.trim();
  P.goal4year=document.getElementById('ep-goal').value.trim();P.goalImportant=document.getElementById('ep-important').value.trim();P.motto=document.getElementById('ep-motto').value.trim();
  sv('drn_p',P);toast();nav('home');
}

/* ---- HOME ---- */
function refreshHome(){
  document.getElementById('g-name').textContent=P.name;
  document.getElementById('g-streak').textContent=calcStreak();
  var tk=todayKey();
  document.getElementById('st-dt').textContent=fmtJP(tk);
  var has=!!E[tk];
  document.getElementById('st-dot').className='st-dot '+(has?'ok':'ng');
  document.getElementById('st-txt').textContent=has?'本日の記録：入力済み ✓':'本日の記録：未入力';
  renderGoalCard();
  renderRecent();
}
function renderGoalCard(){
  var c=document.getElementById('goal-display');
  var hasGoals=P&&(P.goal4year||P.goalImportant||P.motto);
  if(!hasGoals){c.innerHTML='<div class="goal-empty">目標・座右の銘が設定されていません。「編集」から入力しましょう。</div>';return;}
  var html='';
  if(P.goal4year){html+='<div class="goal-item"><div class="goal-item-label">４年間の最終目標</div><div class="goal-item-text">'+esc(P.goal4year)+'</div></div>';}
  if(P.goalImportant){html+='<div class="goal-item"><div class="goal-item-label">そのために大切にすること</div><div class="goal-item-text">'+esc(P.goalImportant)+'</div></div>';}
  if(P.motto){html+='<div class="goal-item"><div class="goal-item-label">座右の銘</div><div class="goal-item-text motto">「'+esc(P.motto)+'」</div></div>';}
  c.innerHTML=html;
}
function renderRecent(){
  var c=document.getElementById('recent-list');
  var ks=Object.keys(E).sort(function(a,b){return b.localeCompare(a);}).slice(0,5);
  if(!ks.length){c.innerHTML='<div class="empty"><div class="empty-ic">📔</div><p style="font-size:14px;line-height:1.7;">まだ記録がありません。<br>今日から記録を始めましょう！</p></div>';return;}
  c.innerHTML=ks.map(function(k){return eiHTML(k,E[k]);}).join('');
}
function buildSel(){
  var d=new Date(),y=d.getFullYear(),m=d.getMonth()+1;
  var ys=document.getElementById('sel-year'),ms=document.getElementById('sel-month');
  ys.innerHTML='';for(var i=y;i>=y-3;i--)ys.innerHTML+='<option value="'+i+'">'+i+'年</option>';
  ms.innerHTML='';for(var i=1;i<=12;i++)ms.innerHTML+='<option value="'+i+'"'+(i===m?' selected':'')+'>'+i+'月</option>';
}

/* ---- DAILY ---- */
function setupDaily(){var tk=todayKey();document.getElementById('d-date').value=tk;loadEByDate(tk);}
function loadEByDate(dk){
  var ex=E[dk];
  if(ex){
    document.getElementById('d-weight').value=ex.weight||'';document.getElementById('d-wake').value=ex.wakeTime||'';document.getElementById('d-sleep').value=ex.sleepTime||'';
    document.getElementById('d-train').value=ex.trainingMenu||'';document.getElementById('d-learn').value=ex.learnings||'';document.getElementById('d-inj').value=ex.injuryNote||'';
    SC={cond:ex.condition||0,fat:ex.fatigue||0,score:ex.score||0};
    ['cond','fat','score'].forEach(function(f){renderSc(f,SC[f]);});setInj(ex.hasInjury||false);
  }else{
    ['d-weight','d-wake','d-sleep','d-train','d-learn','d-inj'].forEach(function(id){document.getElementById(id).value='';});
    SC={cond:0,fat:0,score:0};['cond','fat','score'].forEach(function(f){renderSc(f,0);});setInj(false);
  }
}
function setSc(f,v){SC[f]=v;renderSc(f,v);}
function renderSc(f,v){
  var m={cond:'sc-cond',fat:'sc-fat',score:'sc-score'};
  document.querySelectorAll('#'+m[f]+' .sb').forEach(function(b,i){b.className='sb';if(i+1===v)b.className='sb s'+v;});
}
function setInj(v){
  INJ=v;document.getElementById('inj-no').className='tb'+(!v?' no':'');document.getElementById('inj-yes').className='tb'+(v?' yes':'');document.getElementById('inj-wrap').style.display=v?'block':'none';
}
function saveDaily(){
  var dk=document.getElementById('d-date').value;if(!dk){alert('日付を選択してください');return;}
  E[dk]={date:dk,weight:parseFloat(document.getElementById('d-weight').value)||null,wakeTime:document.getElementById('d-wake').value||null,sleepTime:document.getElementById('d-sleep').value||null,condition:SC.cond,fatigue:SC.fat,score:SC.score,hasInjury:INJ,injuryNote:document.getElementById('d-inj').value.trim(),trainingMenu:document.getElementById('d-train').value.trim(),learnings:document.getElementById('d-learn').value.trim(),savedAt:Date.now()};
  sv('drn_e',E);toast();if(navigator.vibrate)navigator.vibrate(50);
}

/* ---- WEEKLY ---- */
function setupWeekly(){WO=0;renderWkly();}
function chWk(d){WO+=d;renderWkly();}
function renderWkly(){
  var key=wkKey(WO),range=wkRange(WO);
  var lbl=WO===0?'今週':WO===-1?'先週':Math.abs(WO)+'週'+(WO<0?'前':'後');
  document.getElementById('w-lbl').textContent=lbl;document.getElementById('w-dt').textContent=fmtD(range.s)+' 〜 '+fmtD(range.e);
  var ex=W[key]||{};document.getElementById('wk-ref').value=ex.reflection||'';document.getElementById('wk-goal').value=ex.nextGoal||'';
  renderWkSum(range);
}
function renderWkSum(range){
  var c=document.getElementById('w-sum');
  var dates=[];for(var d=new Date(range.s);d<=range.e;d.setDate(d.getDate()+1))dates.push(toKey(new Date(d)));
  var es=dates.map(function(dk){return E[dk];}).filter(Boolean);
  if(!es.length){c.innerHTML='<p style="color:var(--muted);font-size:13px;text-align:center;padding:8px 0;">この週の記録がありません</p>';return;}
  var cs=es.filter(function(e){return e.condition;}),fs=es.filter(function(e){return e.fatigue;});
  var ac=cs.length?(cs.reduce(function(s,e){return s+e.condition;},0)/cs.length).toFixed(1):null;
  var af=fs.length?(fs.reduce(function(s,e){return s+e.fatigue;},0)/fs.length).toFixed(1):null;
  function mini(l,v){return '<div style="background:var(--gbg);border-radius:10px;padding:9px 6px;text-align:center;"><div style="font-size:10px;color:var(--muted);">'+l+'</div><div style="font-size:18px;font-weight:900;color:var(--gm);">'+v+'</div></div>';}
  function pip(v,l){return '<span style="font-size:11px;background:'+SCOLS[v]+'22;color:'+SCOLS[v]+';padding:2px 7px;border-radius:6px;font-weight:700;">'+l+v+'</span>';}
  var html='<div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:8px;margin-bottom:10px;">'+mini('記録日数',es.length+'日')+mini('平均体調',ac||'—')+mini('平均疲労',af||'—')+'</div>';
  html+=dates.map(function(dk){var e=E[dk],dt=new Date(dk);return '<div style="display:flex;align-items:center;gap:8px;padding:5px 0;border-bottom:1px solid var(--gbg);">'+'<span style="font-size:11px;color:var(--muted);min-width:28px;">'+DAYS[dt.getDay()]+'曜</span>'+(e?'<div style="display:flex;gap:5px;flex:1;flex-wrap:wrap;">'+(e.condition?pip(e.condition,'体調'):'')+(e.fatigue?pip(e.fatigue,'疲労'):'')+(e.weight?'<span style="font-size:11px;background:var(--gbg);padding:2px 7px;border-radius:6px;color:var(--gm);">'+e.weight+'kg</span>':'')+'</div>':'<span style="font-size:11px;color:var(--muted);">未記録</span>')+'</div>';}).join('');
  c.innerHTML=html;
}
function saveWeekly(){W[wkKey(WO)]={reflection:document.getElementById('wk-ref').value.trim(),nextGoal:document.getElementById('wk-goal').value.trim(),savedAt:Date.now()};sv('drn_w',W);toast();}

/* ---- HISTORY ---- */
function renderHist(){
  var c=document.getElementById('hist-list');
  var ks=Object.keys(E).sort(function(a,b){return b.localeCompare(a);});
  if(!ks.length){c.innerHTML='<div class="empty"><div class="empty-ic">📊</div><p style="font-size:14px;line-height:1.7;">まだ記録がありません。</p></div>';return;}
  var by={};ks.forEach(function(k){var m=k.slice(0,7);if(!by[m])by[m]=[];by[m].push(k);});
  var html='';
  Object.keys(by).sort(function(a,b){return b.localeCompare(a);}).forEach(function(mon){
    var p=mon.split('-');html+='<div class="stit">'+parseInt(p[0])+'年'+parseInt(p[1])+'月</div>';
    by[mon].forEach(function(k){html+=eiHTML(k,E[k]);});
  });
  c.innerHTML=html;
}
function eiHTML(dk,e){
  var dt=new Date(dk),day=dt.getDate(),mon=dt.getMonth()+1,dow=DAYS[dt.getDay()],sc=e.score;
  var meta=[e.weight?e.weight+'kg':null,e.wakeTime?'起床 '+e.wakeTime:null,e.condition?'体調 '+e.condition:null].filter(Boolean).join(' · ');
  return '<div class="ei" onclick="viewE(\''+dk+'\')">'+'<div class="edb"><div class="ed">'+day+'</div><div class="em">'+mon+'月 '+dow+'曜</div></div>'+'<div class="ei-info"><div class="ei-t">'+fmtJP(dk)+'</div><div class="ei-m">'+(meta||'記録あり')+'</div></div>'+(sc?'<div class="scbadge" style="background:'+SCOLS[sc]+';">'+sc+'</div>':'')+'</div>';
}
function viewE(dk){
  var e=E[dk];if(!e)return;show('sv');
  document.getElementById('v-hdr').textContent=fmtJP(dk);
  var rows=[['体重',e.weight?e.weight+' kg':'—'],['起床時間',e.wakeTime||'—'],['就寝時間',e.sleepTime||'—'],['体調',e.condition?e.condition+' / 5':'—'],['疲労感',e.fatigue?e.fatigue+' / 5':'—'],['怪我・痛み',e.hasInjury?'あり'+(e.injuryNote?': '+e.injuryNote:''):'なし']];
  function dr(arr){return arr.map(function(r){return '<div class="dr"><span class="dk">'+r[0]+'</span><span class="dv">'+r[1]+'</span></div>';}).join('');}
  var html='<div style="padding:16px;">'+'<div class="card"><div class="ctit">📏 身体データ</div>'+dr(rows.slice(0,3))+'</div>'+'<div class="card"><div class="ctit">💪 コンディション</div>'+dr(rows.slice(3))+'</div>';
  if(e.trainingMenu)html+='<div class="card"><div class="ctit">🏋️ トレーニング内容</div><p style="font-size:14px;line-height:1.8;white-space:pre-wrap;">'+esc(e.trainingMenu)+'</p></div>';
  if(e.learnings)html+='<div class="card"><div class="ctit">💡 課題・学び</div><p style="font-size:14px;line-height:1.8;white-space:pre-wrap;">'+esc(e.learnings)+'</p></div>';
  if(e.score)html+='<div class="card" style="text-align:center;padding:20px 16px;"><div class="ctit">⭐ 今日の点数</div><div style="font-size:60px;font-weight:900;color:'+SCOLS[e.score]+';line-height:1;">'+e.score+'</div><div style="font-size:13px;color:'+SCOLS[e.score]+';margin-top:5px;font-weight:700;">'+SLBLS[e.score]+'</div></div>';
  html+='<button class="btn2" onclick="editE(\''+dk+'\')">この記録を編集する</button></div>';
  document.getElementById('v-body').innerHTML=html;
}
function editE(dk){show('sd');document.getElementById('d-date').value=dk;loadEByDate(dk);}

/* ===== PDF ===== */
function openPDF(){
  var y=parseInt(document.getElementById('sel-year').value);var m=parseInt(document.getElementById('sel-month').value);
  document.getElementById('pdf-content').innerHTML=buildReport(y,m);
  document.getElementById('pdf-overlay').classList.add('on');document.getElementById('pdf-content').scrollTop=0;
}
function closePDF(){document.getElementById('pdf-overlay').classList.remove('on');}
function doPrint(){setTimeout(function(){window.print();},100);}

function buildReport(y,m){
  var p2=function(n){return String(n).padStart(2,'0');};
  var dim=new Date(y,m,0).getDate();var mStr=y+'年'+m+'月';
  var sdot=function(v){if(!v)return'<span style="color:#ccc;">—</span>';return'<span class="rpt-dot" style="background:'+SCOLS[v]+';">'+v+'</span>';};

  /* 日別テーブル行 */
  var rows='';
  for(var d=1;d<=dim;d++){
    var dk=y+'-'+p2(m)+'-'+p2(d);var e=E[dk];var dt=new Date(y,m-1,d);var dow=DAYS[dt.getDay()];
    var dc=dt.getDay()===0?'color:#C62828;font-weight:700':dt.getDay()===6?'color:#1B5E20;font-weight:700':'font-weight:700';
    var injTxt=e&&e.hasInjury?('<span style="color:#C62828;font-weight:700;">あり</span>'+(e.injuryNote?'：'+esc(e.injuryNote).slice(0,18):'')):'—';
    rows+='<tr style="'+((!e)?'background:#FAFAFA;':'')+'">'
      +'<td class="tl" style="'+dc+'">'+m+'/'+d+'('+dow+')</td>'
      +'<td>'+(e&&e.weight?e.weight:'—')+'</td>'
      +'<td>'+(e&&e.wakeTime?e.wakeTime:'—')+'</td>'
      +'<td>'+(e&&e.sleepTime?e.sleepTime:'—')+'</td>'
      +'<td>'+sdot(e&&e.condition)+'</td>'
      +'<td>'+sdot(e&&e.fatigue)+'</td>'
      +'<td>'+sdot(e&&e.score)+'</td>'
      +'<td class="tl sm">'+injTxt+'</td>'
      +'</tr>';
  }

  /* 週別振り返り */
  var weeks=getMonthWeeks(y,m);
  var weeksHtml=weeks.map(function(wk,i){
    var dts=getDates(wk.s,wk.e);var cnt=dts.filter(function(dk){return E[dk];}).length;
    var key=wkKey2(wk.s);var wd=W[key]||{};
    return '<div class="rpt-week"><div class="rpt-week-hdr">第'+(i+1)+'週　'+fmtD(wk.s)+' 〜 '+fmtD(wk.e)+'　（記録 '+cnt+'/'+dts.length+' 日）</div><div class="rpt-week-body">'
      +(wd.reflection?'<div class="rpt-wlbl">▶ 今週の振り返り</div><div class="rpt-wval">'+esc(wd.reflection)+'</div>':'')
      +(wd.nextGoal?'<div class="rpt-wlbl">▶ 来週の目標</div><div class="rpt-wval">'+esc(wd.nextGoal)+'</div>':'')
      +(!wd.reflection&&!wd.nextGoal?'<p style="font-size:9pt;color:#888;">振り返りが入力されていません</p>':'')
      +'</div></div>';
  }).join('');

  /* トレーニング記録 */
  var notesHtml='';
  for(var d=1;d<=dim;d++){var dk2=y+'-'+p2(m)+'-'+p2(d);var e2=E[dk2];if(e2&&(e2.trainingMenu||e2.learnings)){var dt2=new Date(y,m-1,d);notesHtml+='<div class="rpt-note"><div class="rpt-note-dt">'+m+'/'+d+'（'+DAYS[dt2.getDay()]+'曜日）</div>'+(e2.trainingMenu?'<div class="rpt-note-lbl">トレーニング内容</div><div class="rpt-note-val">'+esc(e2.trainingMenu)+'</div>':'')+(e2.learnings?'<div class="rpt-note-lbl">課題・学び</div><div class="rpt-note-val">'+esc(e2.learnings)+'</div>':'')+'</div>';}}

  /* 統計 */
  var allE=[];for(var d=1;d<=dim;d++){var e3=E[y+'-'+p2(m)+'-'+p2(d)];if(e3)allE.push(e3);}
  var avg=function(f){var filt=allE.filter(function(e){return e[f];});return filt.length?(filt.reduce(function(s,e){return s+e[f];},0)/filt.length).toFixed(1):'—';};
  var injDays=allE.filter(function(e){return e.hasInjury;}).length;

  /* 目標セクション */
  var goalsHtml='';
  if(P&&(P.goal4year||P.goalImportant||P.motto)){
    goalsHtml='<div class="rpt-goals">'
      +'<div class="rpt-goals-hdr">🎯 目標・信念</div>'
      +'<div class="rpt-goals-body">'
      +(P.goal4year?'<div class="rpt-goal-item"><div class="rgl">４年間の最終目標</div><div class="rgv">'+esc(P.goal4year)+'</div></div>':'')
      +(P.goalImportant?'<div class="rpt-goal-item"><div class="rgl">大切にしていること</div><div class="rgv">'+esc(P.goalImportant)+'</div></div>':'')
      +(P.motto?'<div class="rpt-goal-item rpt-motto"><div class="rgl">座右の銘</div><div class="rgv" style="font-weight:700;color:#3B6621;">「'+esc(P.motto)+'」</div></div>':'')
      +'</div></div>';
  }

  return '<div class="rpt">'
    +'<div class="rpt-hdr"><div><div class="rpt-hdr-title">D-Reflection Note</div><div class="rpt-hdr-sub">大東文化大学 スポーツ・健康科学部　スポーツフィールドワーク 月間記録レポート</div></div><div class="rpt-hdr-logo">DR</div></div>'
    +'<div class="rpt-info"><table><tr>'
    +'<td class="lbl">氏名</td><td class="val" style="min-width:80px;">'+(P?esc(P.name):'—')+'</td>'
    +'<td class="lbl">学籍番号</td><td class="val">'+(P&&P.sid?esc(P.sid):'—')+'</td>'
    +'<td class="lbl">担当種目</td><td class="val">'+(P&&P.sport?esc(P.sport):'—')+'</td>'
    +'<td class="lbl">記録期間</td><td class="val">'+mStr+'</td>'
    +'</tr></table></div>'
    +goalsHtml
    +'<div class="rpt-sec"><div class="rpt-sec-tit">📊 月間サマリー</div>'
    +'<div class="rpt-stats">'
    +'<div class="rpt-stat"><div class="rpt-stat-lbl">記録日数</div><div class="rpt-stat-val">'+allE.length+'</div><div class="rpt-stat-sub">/ '+dim+' 日</div></div>'
    +'<div class="rpt-stat"><div class="rpt-stat-lbl">平均体調</div><div class="rpt-stat-val">'+avg('condition')+'</div><div class="rpt-stat-sub">/ 5</div></div>'
    +'<div class="rpt-stat"><div class="rpt-stat-lbl">平均疲労感</div><div class="rpt-stat-val">'+avg('fatigue')+'</div><div class="rpt-stat-sub">/ 5</div></div>'
    +'<div class="rpt-stat"><div class="rpt-stat-lbl">平均点数</div><div class="rpt-stat-val">'+avg('score')+'</div><div class="rpt-stat-sub">/ 5</div></div>'
    +'<div class="rpt-stat"><div class="rpt-stat-lbl">怪我・痛みの日</div><div class="rpt-stat-val" style="color:'+(injDays>0?'#C62828':'#3B6621')+';">'+injDays+'</div><div class="rpt-stat-sub">日</div></div>'
    +'<div class="rpt-stat"><div class="rpt-stat-lbl">達成率</div><div class="rpt-stat-val">'+(dim>0?Math.round(allE.length/dim*100):0)+'</div><div class="rpt-stat-sub">%</div></div>'
    +'</div></div>'
    +'<div class="rpt-sec"><div class="rpt-sec-tit">📅 日別記録</div><table class="rpt-tbl"><thead><tr><th class="tl">日付</th><th>体重(kg)</th><th>起床</th><th>就寝</th><th>体調</th><th>疲労感</th><th>点数</th><th class="tl">怪我・痛み</th></tr></thead><tbody>'+rows+'</tbody></table></div>'
    +'<div class="rpt-sec"><div class="rpt-sec-tit">📝 週別振り返り</div>'+weeksHtml+'</div>'
    +(notesHtml?'<div class="rpt-sec"><div class="rpt-sec-tit">🏋️ トレーニング記録・課題</div>'+notesHtml+'</div>':'')
    +'<div class="rpt-footer"><div style="font-size:9pt;color:#5A6E50;">大東文化大学 スポーツ・健康科学部　スポーツフィールドワーク<br>'+(P?esc(P.name):'')+'　'+mStr+'</div>'
    +'<div style="display:flex;gap:24px;align-items:flex-end;"><div style="text-align:center;"><div class="rpt-sig">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div><div style="font-size:9pt;color:#5A6E50;margin-top:4px;">提出日</div></div>'
    +'<div style="text-align:center;"><div class="rpt-sig">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;</div><div style="font-size:9pt;color:#5A6E50;margin-top:4px;">担当教員確認</div></div>'
    +'</div></div></div>';
}

/* ---- WEEK/DATE HELPERS ---- */
function getMonthWeeks(y,m){
  var weeks=[],first=new Date(y,m-1,1),last=new Date(y,m,0),cur=new Date(first);
  while(cur<=last){var dow=cur.getDay()||7;var ws=new Date(cur);ws.setDate(cur.getDate()-(dow-1));if(ws<first)ws=new Date(first);var we=new Date(ws);we.setDate(ws.getDate()+6);if(we>last)we=new Date(last);weeks.push({s:new Date(ws),e:new Date(we)});cur=new Date(we);cur.setDate(we.getDate()+1);}
  return weeks;
}
function getDates(s,e){var res=[];for(var d=new Date(s);d<=e;d.setDate(d.getDate()+1))res.push(toKey(new Date(d)));return res;}
function wkKey(off){var d=new Date();d.setDate(d.getDate()-((d.getDay()||7)-1)+(off*7));return wkKey2(d);}
function wkKey2(d){var t=new Date(Date.UTC(d.getFullYear(),d.getMonth(),d.getDate()));var dn=t.getUTCDay()||7;t.setUTCDate(t.getUTCDate()+4-dn);var ys=new Date(Date.UTC(t.getUTCFullYear(),0,1));return t.getUTCFullYear()+'-W'+String(Math.ceil((((t-ys)/86400000)+1)/7)).padStart(2,'0');}
function wkRange(off){var d=new Date(),day=d.getDay();var s=new Date(d);s.setDate(d.getDate()-((day||7)-1)+(off*7));s.setHours(0,0,0,0);var e=new Date(s);e.setDate(s.getDate()+6);return{s:s,e:e};}

/* ---- UTILS ---- */
function todayKey(){return toKey(new Date());}
function toKey(d){return d.getFullYear()+'-'+String(d.getMonth()+1).padStart(2,'0')+'-'+String(d.getDate()).padStart(2,'0');}
function fmtD(d){return(d.getMonth()+1)+'/'+d.getDate();}
function fmtJP(dk){if(!dk)return'—';var p=dk.split('-'),dt=new Date(dk);return parseInt(p[0])+'年'+parseInt(p[1])+'月'+parseInt(p[2])+'日（'+DAYS[dt.getDay()]+'）';}
function esc(s){return s?String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'):'';  }
function calcStreak(){var s=0,d=new Date();while(true){var k=toKey(d);if(E[k]){s++;d.setDate(d.getDate()-1);}else break;}return s;}
var _tt;function toast(){var el=document.getElementById('toast');el.classList.add('show');clearTimeout(_tt);_tt=setTimeout(function(){el.classList.remove('show');},2000);}

init();
</script>
